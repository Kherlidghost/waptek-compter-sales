NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_SECRET_KEY=your-server-only-supabase-secret-key

# WhatsApp Click-to-Chat
# International format, digits only, e.g. 2348012345678
# Primary source: company_settings.whatsapp_number (set via /admin/settings)
# This env var is a fallback used when Supabase is not configured.
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# Production site URL (used to build product inquiry links)
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app

# Optional production email provider.
# Used only by server-side email utilities. Leave blank to simulate emails.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS="WAPTEK COMPUTER SERVICES <noreply@yourdomain.com>"
